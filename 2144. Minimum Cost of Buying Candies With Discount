class Solution {
public:
    int minimumCost(vector<int>& cost) {
        int n,ans=0;
        n = cost.size();

        sort(cost.begin(),cost.end(),greater<int>());

        for(int i=0; i<n;i+=3){
            ans += cost[i];
            if(i+1<n)ans += cost[i+1];
        }
        return ans;

    }
};
